{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/images/**", "/icons/**"],
        "urls": [
          "https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/**",
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**",
          "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api",
      "urls": ["https://7aeaed4d-9420-4504-bc88-1c6c1a6fd6ec.mock.pstmn.io/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ]
}
